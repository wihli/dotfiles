# Split a single-pane window into a 4x2 grid.
split-window -v -p 50

select-pane -t "{top-left}"
split-window -h -p 75
select-pane -t "{top-right}"
split-window -h -p 66
select-pane -t "{top-right}"
split-window -h -p 50

select-pane -t "{bottom-left}"
split-window -h -p 75
select-pane -t "{bottom-right}"
split-window -h -p 66
select-pane -t "{bottom-right}"
split-window -h -p 50

select-pane -t "{top-left}"
