#!/usr/bin/env bash

# Notify that an interactive agent is waiting, and mark the current tmux pane.
# Keep stdout empty: Codex and Claude hooks may parse hook stdout.

set +e

mode="ready"
if [ "${1:-}" = "--clear" ]; then
    mode="clear"
    shift
fi

agent="${1:-Agent}"
state_home="${XDG_STATE_HOME:-$HOME/.local/state}"
state_dir="$state_home/agent-notify-ready"
hook_input=""
if [ ! -t 0 ]; then
    hook_input=$(cat 2>/dev/null || true)
fi

log_event() {
    local event target detail
    event=$1
    target=${2:-}
    detail=${3:-}

    mkdir -p "$state_dir" 2>/dev/null || return 0
    printf '%s event=%s agent=%s target=%s detail=%s\n' \
        "$(date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null)" \
        "$event" "$agent" "$target" "$detail" >> "$state_dir/events.log" 2>/dev/null || true
}

sanitize_key() {
    printf '%s' "$1" | tr -c 'A-Za-z0-9_.-' '_'
}

shell_quote() {
    printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

json_field() {
    local field
    field=$1

    [ -n "$hook_input" ] || return 1
    command -v jq >/dev/null 2>&1 || return 1
    printf '%s' "$hook_input" | jq -er --arg field "$field" '.[$field] // empty' 2>/dev/null
}

title_from_prompt() {
    local prompt lower
    prompt=$1
    lower=$(printf '%s' "$prompt" | tr '[:upper:]' '[:lower:]')

    case "$lower" in
        *marathon*training*plan*|*training*plan*marathon*|*couch*marathon*) printf '%s\n' "Marathon Training Plan"; return 0 ;;
        *tmux*title*|*title*tmux*) printf '%s\n' "Tmux Title Hook"; return 0 ;;
        *poem*title*|*title*poem*) printf '%s\n' "Poem Title Test"; return 0 ;;
        *poem*) printf '%s\n' "Write Poem"; return 0 ;;
    esac

    printf '%s\n' "$prompt" | tr '\n' ' ' | awk '
        BEGIN {
            split("build create debug draft explain find fix give help look make plan review search summarize tell write", verbs)
            for (i in verbs) action[verbs[i]]=1
            split("a about actually an and are as asked at be but by can could completely did different do does for from get give got had has have how i if in into is it its just let me my no not now of ok okay on or our please should so somebody something that the thing this to two up six want wanted was way we were what when where why will with word words working you your tell see happens happen wait always ready codex small summary write writes like", stop)
            for (i in stop) skip[stop[i]]=1
        }
        {
            start = 1
            for (i = 1; i <= NF; i++) {
                word = tolower($i)
                gsub(/[^[:alnum:]_-]/, "", word)
                if (word in action) {
                    start = i + 1
                    if (start <= NF) {
                        next_word = tolower($(start))
                        gsub(/[^[:alnum:]_-]/, "", next_word)
                        if (next_word == "me" || next_word == "us") {
                            start++
                        }
                    }
                    if (start <= NF) {
                        next_word = tolower($(start))
                        gsub(/[^[:alnum:]_-]/, "", next_word)
                        if (next_word == "a" || next_word == "an" || next_word == "the" || next_word == "to") {
                            start++
                        }
                    }
                }
            }
            for (i = start; i <= NF; i++) {
                word = tolower($i)
                gsub(/[^[:alnum:]_-]/, "", word)
                if (word == "" || word in skip || word ~ /^[0-9]+$/ || seen[word]++) {
                    continue
                }
                words[++n] = word
                if (n == 6) {
                    break
                }
            }
        }
        END {
            if (n == 0) {
                print "Codex Session"
                exit
            }
            if (n == 1) {
                words[++n] = "work"
            }
            for (i = 1; i <= n; i++) {
                word = toupper(substr(words[i], 1, 1)) substr(words[i], 2)
                out = out (i == 1 ? "" : " ") word
            }
            print out
        }
    '
}

tmux_target() {
    [ -n "${TMUX_PANE:-}" ] || return 1
    command -v tmux >/dev/null 2>&1 || return 1
    printf '%s' "$TMUX_PANE"
}

tmux_key() {
    local target socket
    target=$(tmux_target) || return 1
    socket=${TMUX%%,*}
    sanitize_key "${socket}_${target}"
}

tmux_display() {
    local target format
    target=$(tmux_target) || return 1
    format=$1
    tmux display-message -p -t "$target" "$format" 2>/dev/null
}

set_tmux_title() {
    local target title marker delay cmd
    target=$1
    title=$2
    marker=${3:-}

    tmux select-pane -t "$target" -T "$title" >/dev/null 2>&1 || true

    # Codex writes its own spinner/idle title around Stop hooks. Reapply shortly
    # after the hook returns so the human-visible ready marker wins last.
    for delay in 0.2 1 2; do
        if [ -n "$marker" ]; then
            cmd="sleep $delay; [ -f $(shell_quote "$marker") ] && tmux select-pane -t $(shell_quote "$target") -T $(shell_quote "$title") >/dev/null 2>&1"
        else
            cmd="sleep $delay; tmux select-pane -t $(shell_quote "$target") -T $(shell_quote "$title") >/dev/null 2>&1"
        fi
        tmux run-shell -b "$cmd" >/dev/null 2>&1 || true
    done
}

remember_prompt_title() {
    local target key prompt title
    target=$(tmux_target) || {
        log_event "prompt-title-no-tmux" "" ""
        return 0
    }
    key=$(tmux_key) || {
        log_event "prompt-title-no-key" "$target" ""
        return 0
    }
    prompt=$(json_field "prompt")
    [ -n "$prompt" ] || {
        log_event "prompt-title-no-prompt" "$target" ""
        return 0
    }

    mkdir -p "$state_dir" 2>/dev/null || return 0
    title=$(title_from_prompt "$prompt")
    printf '%s' "$title" > "$state_dir/$key.summary" 2>/dev/null || true
    rm -f "$state_dir/$key.ready" 2>/dev/null || true
    log_event "prompt-title" "$target" "$title"
}

mark_tmux_ready() {
    local target key current_title ready_marker title
    target=$(tmux_target) || {
        log_event "title-no-tmux" "" ""
        return 0
    }
    key=$(tmux_key) || {
        log_event "title-no-key" "$target" ""
        return 0
    }
    mkdir -p "$state_dir" 2>/dev/null || return 0

    current_title=$(tmux_display '#{pane_title}')
    printf '%s' "$current_title" > "$state_dir/$key.title" 2>/dev/null || true
    ready_marker="$state_dir/$key.ready"
    : > "$ready_marker" 2>/dev/null || true
    if [ -f "$state_dir/$key.summary" ]; then
        title=$(cat "$state_dir/$key.summary" 2>/dev/null)
    else
        title=$(basename "$PWD" 2>/dev/null)
    fi
    [ -n "$title" ] || title="$agent"
    log_event "title" "$target" "$title"
    set_tmux_title "$target" "$title" "$ready_marker"
}

clear_tmux_ready() {
    local target key current_title restore_title
    target=$(tmux_target) || {
        log_event "clear-no-tmux" "" ""
        return 0
    }
    key=$(tmux_key) || {
        log_event "clear-no-key" "$target" ""
        return 0
    }

    current_title=$(tmux_display '#{pane_title}')
    rm -f "$state_dir/$key.ready" 2>/dev/null || true
    case "$current_title" in
        READY\ *)
            if [ -f "$state_dir/$key.title" ]; then
                restore_title=$(cat "$state_dir/$key.title" 2>/dev/null)
            else
                restore_title="$agent"
            fi
            log_event "clear" "$target" "$current_title"
            tmux select-pane -t "$target" -T "$restore_title" >/dev/null 2>&1 || true
            rm -f "$state_dir/$key.title" 2>/dev/null || true
            ;;
        *)
            log_event "clear-skip" "$target" "$current_title"
            ;;
    esac
}

bundle_for_process_name() {
    case "$1" in
        Terminal) printf '%s\n' "com.apple.Terminal" ;;
        iTerm2) printf '%s\n' "com.googlecode.iterm2" ;;
        Ghostty|ghostty) printf '%s\n' "com.mitchellh.ghostty" ;;
        wezterm|wezterm-gui|WezTerm) printf '%s\n' "com.github.wez.wezterm" ;;
        kitty|Kitty) printf '%s\n' "net.kovidgoyal.kitty" ;;
        Alacritty|alacritty) printf '%s\n' "org.alacritty" ;;
        *) return 1 ;;
    esac
}

bundle_from_pid_chain() {
    local pid comm base bundle i
    pid=$1
    i=0
    while [ -n "$pid" ] && [ "$pid" -gt 1 ] 2>/dev/null && [ "$i" -lt 25 ]; do
        comm=$(ps -p "$pid" -o comm= 2>/dev/null | sed 's/^ *//;s/ *$//')
        base=$(basename "$comm" 2>/dev/null)
        bundle=$(bundle_for_process_name "$base") && {
            printf '%s\n' "$bundle"
            return 0
        }
        pid=$(ps -p "$pid" -o ppid= 2>/dev/null | awk '{print $1}')
        i=$((i + 1))
    done
    return 1
}

terminal_bundle() {
    local bundle client_pid client_term
    if [ -n "${AGENT_NOTIFY_TERMINAL_BUNDLE:-}" ]; then
        printf '%s\n' "$AGENT_NOTIFY_TERMINAL_BUNDLE"
        return 0
    fi

    if [ -n "${TMUX:-}" ] && command -v tmux >/dev/null 2>&1; then
        client_pid=$(tmux display-message -p '#{client_pid}' 2>/dev/null | awk '{print $1}')
        bundle=$(bundle_from_pid_chain "$client_pid") && {
            printf '%s\n' "$bundle"
            return 0
        }

        client_term=$(tmux display-message -p '#{client_termname}' 2>/dev/null)
        case "$client_term" in
            *ghostty*) printf '%s\n' "com.mitchellh.ghostty"; return 0 ;;
            *kitty*) printf '%s\n' "net.kovidgoyal.kitty"; return 0 ;;
            *wezterm*) printf '%s\n' "com.github.wez.wezterm"; return 0 ;;
            *alacritty*) printf '%s\n' "org.alacritty"; return 0 ;;
        esac
    fi

    case "${TERM_PROGRAM:-}" in
        Apple_Terminal) printf '%s\n' "com.apple.Terminal" ;;
        iTerm.app) printf '%s\n' "com.googlecode.iterm2" ;;
        Ghostty|ghostty) printf '%s\n' "com.mitchellh.ghostty" ;;
        WezTerm|wezterm) printf '%s\n' "com.github.wez.wezterm" ;;
        kitty|Kitty) printf '%s\n' "net.kovidgoyal.kitty" ;;
        Alacritty|alacritty) printf '%s\n' "org.alacritty" ;;
        *) return 1 ;;
    esac
}

notification_message() {
    local cwd_name tmux_label
    cwd_name=$(basename "$PWD" 2>/dev/null)
    tmux_label=$(tmux_display '#{session_name}:#{window_index}.#{pane_index} #{pane_id}' 2>/dev/null)
    if [ -n "$tmux_label" ]; then
        printf '%s | %s\n' "$cwd_name" "$tmux_label"
    else
        printf '%s\n' "$cwd_name"
    fi
}

notify_ready() {
    local title message group notifier bundle
    title="$agent ready"
    message=$(notification_message)
    group="agent-ready-$(tmux_key 2>/dev/null || sanitize_key "$agent-$PWD")"

    case "$(uname 2>/dev/null)" in
        Darwin)
            notifier=$(command -v terminal-notifier 2>/dev/null)
            if [ -n "$notifier" ]; then
                bundle=$(terminal_bundle 2>/dev/null)
                if [ -n "$bundle" ]; then
                    "$notifier" -title "$title" -message "$message" -group "$group" -sound Glass -activate "$bundle" >/dev/null 2>&1 && return 0
                else
                    "$notifier" -title "$title" -message "$message" -group "$group" -sound Glass >/dev/null 2>&1 && return 0
                fi
            fi
            if command -v osascript >/dev/null 2>&1; then
                osascript \
                    -e 'on run argv' \
                    -e 'display notification (item 2 of argv) with title (item 1 of argv)' \
                    -e 'end run' \
                    "$title" "$message" >/dev/null 2>&1 || true
            fi
            ;;
        *)
            if [ -n "${DISPLAY:-}" ] && command -v notify-send >/dev/null 2>&1; then
                notify-send "$title" "$message" >/dev/null 2>&1 || true
            fi
            ;;
    esac
}

case "$mode" in
    clear)
        if [ "$(json_field "hook_event_name")" = "UserPromptSubmit" ]; then
            remember_prompt_title
        else
            clear_tmux_ready
        fi
        ;;
    *)
        mark_tmux_ready
        notify_ready
        ;;
esac

exit 0
