#!/bin/bash
# Pre-push hook: use Claude to review outgoing changes for private info leaks.
# Installed by install.sh via core.hooksPath.

set -uo pipefail

# Skip if claude CLI isn't available
if ! command -v claude &>/dev/null; then
    echo "[pre-push] claude CLI not found, skipping privacy review"
    exit 0
fi

# Parse pre-push stdin to get the range of commits being pushed.
# Format: <local ref> <local sha> <remote ref> <remote sha>
ZERO="0000000000000000000000000000000000000000"
while read -r _ local_sha _ remote_sha; do
    if [ "$local_sha" = "$ZERO" ]; then
        # Deleting a remote ref, nothing to review
        continue
    fi

    if [ "$remote_sha" = "$ZERO" ]; then
        # New branch — review all commits
        diff=$(git diff --no-color "$(git merge-base HEAD main 2>/dev/null || echo HEAD~1)..HEAD" 2>/dev/null || git show --no-color HEAD)
    else
        diff=$(git diff --no-color "$remote_sha..$local_sha")
    fi

    if [ -z "$diff" ]; then
        continue
    fi

    echo "[pre-push] Reviewing changes for private info leaks..."

    verdict=$(echo "$diff" | claude -p --model sonnet \
        --allowedTools "" \
        --max-turns 1 \
        "You are a privacy reviewer for a PUBLIC dotfiles repo. This diff is about to be pushed to a public GitHub repository.

About the owner: Eric Ihli is a Vanta employee on the core-platform team. He uses Anthropic's Claude Code and OpenAI's Codex CLI as primary AI dev tools — both are public third-party products. His dotfiles are split into a public repo (wihli-dotfiles) and a private repo (wihli-dotfiles-private); Vanta-specific content lives in the private repo.

Block (FAIL) only if the diff reveals any of:
- Vanta customer names or customer-specific data
- Vanta-internal Slack channel names (e.g. anything that looks like an internal-only channel)
- Vanta-internal AWS account IDs, hostnames, or IP addresses
- Vanta product codenames, internal project codenames, or internal repo names
- Vanta-internal tool URLs (Confluence/Notion/Jira/Guru/internal go-links)
- Specific Vanta operational details: oncall rotations, incident specifics, migration tracker contents
- Credentials, API keys, tokens, or session cookies — even in examples

Allow (PASS) anything that's generic or about public third-party tools:
- The owner's name (Eric Ihli) and work email (eric.ihli@vanta.com)
- The generic employer name 'Vanta' on its own
- Generic third-party tool names (Terraform, Datadog, GitHub, etc.)
- Implementation details of PUBLIC third-party developer tools — e.g. Claude Code storage paths under ~/.claude/, Codex CLI storage paths under ~/.codex/, their schemas, JSONL formats, sqlite table layouts. These tools are public; documenting how they work locally is fine.
- Shell aliases, editor config, prompt config, keybindings
- AI agent instructions about coding style and workflow preferences
- Skills and subagents with generic functionality
- References to the companion private repo (wihli-dotfiles-private) — the public/private split is the whole point of this setup
- Public GitHub repo names and URLs

Edge-case guidance:
- 'Vanta' as a word, by itself, is fine. 'Vanta-<specific-internal-thing>' is not.
- A path that LOOKS like internal infrastructure (e.g. ~/.codex/state_5.sqlite, ~/.claude/projects/) is fine if the surrounding tool is a known public product. When in doubt, ask: would a public web search of this path turn up OpenAI/Anthropic docs or community discussion? If yes, PASS.
- Do NOT attribute third-party tool internals (Codex, Claude Code, etc.) to Vanta. They are not Vanta tools.

Respond with EXACTLY one of:
PASS — if nothing private is found
FAIL — followed by a brief explanation of what was found and why it's a concern

Do not include any other text." 2>&1)
    claude_exit=$?

    if [ $claude_exit -ne 0 ]; then
        echo "[pre-push] WARNING: claude review failed (exit $claude_exit): $verdict"
        echo "[pre-push] Allowing push — review manually or retry."
        continue
    fi

    if echo "$verdict" | grep -q "^FAIL"; then
        echo ""
        echo "[pre-push] BLOCKED — potential private info in outgoing changes:"
        echo "$verdict" | tail -n +1
        echo ""
        echo "Fix the issue and try again, or bypass with: git push --no-verify"
        exit 1
    fi

    echo "[pre-push] Privacy review passed."
done

exit 0
